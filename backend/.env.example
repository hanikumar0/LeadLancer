NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadlancer

# Security
JWT_SECRET=your_super_secret_jwt_string_12345
CLIENT_URL=http://localhost:3000

# xAI (Grok)
XAI_API_KEY=xai-your_grok_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-beta

# Email Outreach
RESEND_API_KEY=re_your_resend_key
SYSTEM_SENDER_EMAIL=outreach@yourdomain.com

# Scraping
PROXY_URL=
