# LeadLancer Root Env Example

# Backend API
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000/api
APP_URL=http://localhost:3000

# Web Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Mobile App
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadlancer

# Authentication
JWT_SECRET=your_super_secret_jwt_string_12345
JWT_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=optional_refresh_secret

# AI Provider (Grok / xAI)
XAI_API_KEY=xai-your_grok_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-beta

# Email Provider (Resend)
RESEND_API_KEY=re_your_resend_key
SYSTEM_SENDER_EMAIL=outreach@yourdomain.com

# Scraping
PROXY_URL=optional_proxy_url
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=30000
SCRAPER_CONCURRENCY=2

# Security
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=optional_cookie_secret
ENCRYPTION_KEY=optional_encryption_key

# Redis / Queue (Future)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Push Notifications (Future)
EXPO_ACCESS_TOKEN=

# Monitoring (Future)
SENTRY_DSN=

# Storage (Future)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=

# Payments (Future)
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
